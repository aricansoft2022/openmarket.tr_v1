{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "openmarket-tr",
  "compatibility_date": "2026-07-12",
  "compatibility_flags": ["nodejs_compat"],
  "main": "./workers/app.ts",
  "observability": {
    "enabled": true,
  },
  "vars": {
    "APP_ENV": "local",
    "COMMIT_SHA": "local",
  },
}
