{
  "name": "openmarket-tr",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.22.0"
  },
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "preview": "npm run build && vite preview",
    "deploy": "npm run build && wrangler deploy",
    "typegen": "wrangler types && react-router typegen",
    "typecheck": "npm run typegen && tsc -b",
    "test": "vitest",
    "test:run": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:check": "drizzle-kit check",
    "db:verify": "npm run db:migrate && node scripts/verify-database.mjs",
    "db:verify:auth": "tsx scripts/verify-auth-persistence.ts",
    "db:verify:registration": "tsx scripts/verify-registration-flow.ts",
    "db:verify:recovery": "tsx scripts/verify-auth-recovery.ts",
    "db:verify:google": "tsx scripts/verify-google-oauth-policy.ts",
    "db:verify:google-linking": "tsx scripts/verify-google-account-linking.ts",
    "db:verify:business-identity": "tsx scripts/verify-business-identity.ts",
    "db:verify:business-identity-onboarding": "tsx scripts/verify-business-identity-onboarding.ts",
    "db:verify:business-identity-evidence": "tsx scripts/verify-business-identity-evidence.ts",
    "db:verify:business-identity-review": "tsx scripts/verify-business-identity-review-authorization.ts",
    "db:verify:platform-staff-management": "tsx scripts/verify-platform-staff-management.ts",
    "db:seed:supplier-catalogue": "tsx scripts/seed-supplier-launch-catalogue.ts",
    "db:verify:supplier-catalogue": "tsx scripts/verify-supplier-launch-catalogue.ts",
    "db:verify:supplier-company": "tsx scripts/verify-supplier-company-foundation.ts",
    "db:seed:supplier-documents": "tsx scripts/seed-supplier-document-catalogue.ts",
    "db:verify:supplier-documents": "tsx scripts/verify-supplier-document-catalogue.ts",
    "db:verify:supplier-document-lifecycle": "tsx scripts/verify-supplier-document-lifecycle.ts",
    "db:verify:supplier-activation": "tsx scripts/verify-supplier-activation.ts",
    "db:local:up": "docker compose up -d postgres",
    "db:local:down": "docker compose down",
    "db:local:reset": "docker compose down -v",
    "db:local:logs": "docker compose logs -f postgres",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docs:check": "node scripts/check-docs.mjs",
    "config:check": "node scripts/check-runtime-contract.mjs",
    "verify": "npm run format:check && npm run docs:check && npm run config:check && npm run typecheck && npm run test:run && npm run build",
    "postinstall": "wrangler types",
    "spec:materialize": "node scripts/materialize-spec.mjs"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "1.6.23",
    "better-auth": "1.6.23",
    "drizzle-orm": "0.45.2",
    "pg": "8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router": "8.2.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.44.0",
    "@cloudflare/vitest-pool-workers": "0.18.4",
    "@react-router/dev": "8.2.0",
    "@types/node": "26.1.1",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "0.31.10",
    "prettier": "3.9.5",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "wrangler": "4.110.0",
    "dotenv": "17.4.2"
  }
}
